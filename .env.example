# Credenciais Ubidots - copie para .env e preencha
# IMPORTANTE: informe apenas o HOST (sem /api/v1.6) - o app monta v1.6 e v2.0 sozinho

# Plataforma JKControl (jkcontrol.online)
JKCONTROL_BASE_URL=https://jkcontrol.online
JKCONTROL_TOKEN=cole_seu_token_aqui

# Ubidots Industrial (nuvem oficial)
UBIDOTS_BASE_URL=https://industrial.api.ubidots.com
UBIDOTS_TOKEN=cole_seu_token_aqui

# ============ IA (todos opcionais - configure ao menos 1 para a pagina /ai funcionar) ============

# Anthropic Claude - console.anthropic.com  ($5 gratis no signup)
ANTHROPIC_API_KEY=

# OpenAI GPT - platform.openai.com  ($5 gratis nos primeiros 90 dias)
OPENAI_API_KEY=

# Google Gemini - aistudio.google.com  (free tier generoso ~1500 req/dia)
GOOGLE_API_KEY=

# Ollama local - precisa ter o Ollama instalado em ollama.com e ter feito pull do modelo
OLLAMA_BASE_URL=

# Servidor
HOST=127.0.0.1
PORT=8000
